{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@clouddesk/protocol": ["../../packages/protocol/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../../packages/protocol/src/**/*.ts"]
}
