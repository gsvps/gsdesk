{
  "name": "@clouddesk/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "deploy": "npm run db:migrate && wrangler deploy"
  },
  "dependencies": {
    "@clouddesk/protocol": "*",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.0"
  }
}
